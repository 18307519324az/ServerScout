{
  "mcpServers": {
    "software-engineer": {
      "command": "npx",
      "args": [
        "-y",
        "@rajawatrajat/mcp-software-engineer"
      ]
    },
    "springboot-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@pradeepmajji702/springboot-mcp"
      ],
      "env": {
        "SWAGGER_URL": "http://localhost:8080/v3/api-docs"
      }
    },
    "seed4j": {
      "command": "npx",
      "args": [
        "-y",
        "seed4j-mcp"
      ],
      "env": {
        "SEED4J_BASE_URL": "http://localhost:1339"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  }
}