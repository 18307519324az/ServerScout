# Copy to /opt/serverscout/.env and update as needed
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/serverscout?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=serverscout
SPRING_DATASOURCE_PASSWORD=1A5089879282

JWT_SECRET=change-me-to-at-least-32-chars
LOG_LEVEL=INFO

# Optional Redis for same-target concurrency across multi-instance deployment
SCAN_TARGET_CONCURRENCY_USE_REDIS=false
SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379
