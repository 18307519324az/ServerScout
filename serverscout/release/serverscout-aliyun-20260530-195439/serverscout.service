[Unit]
Description=ServerScout Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/serverscout
EnvironmentFile=-/opt/serverscout/.env
ExecStart=/bin/bash /opt/serverscout/start.sh
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
